vec2 projectPrevNdc(vec3 worldPos) {
    vec4 clip = worldPush.prevViewProj * vec4(worldPos - worldPush.camOffset + worldPush.camDelta, 1.0);
    return clip.xy / clip.w;
}

vec2 previousReflectionNdc(vec3 surfacePos, vec3 surfaceNormal, vec3 reflectedWorldPos, vec3 reflectedMotionPrev) {
    vec3 n = normalize(surfaceNormal);
    vec3 prevHit = reflectedWorldPos - reflectedMotionPrev;
    vec3 mirroredHit = prevHit - 2.0 * n * dot(prevHit - surfacePos, n);
    return projectPrevNdc(mirroredHit);
}

vec2 specularReflectionMotion(vec3 surfacePos, vec3 primaryDir, vec2 currentNdc, vec2 size, float primaryConeSpread) {
    if (length(gv_normal) < 0.5 || max(gv_specAlb.r, max(gv_specAlb.g, gv_specAlb.b)) <= 0.001 || gv_rough > 0.5) {
        return vec2(0.0, 0.0);
    }

    vec3 n = normalize(gv_normal);
    vec3 specDir = reflect(primaryDir, n);
    payload.hitT = -1.0;
    payloadSetTraceState(false,
            max(length(surfacePos - worldPush.camOffset) * primaryConeSpread, RAY_CONE_MIN_WIDTH),
            max(primaryConeSpread, RAY_CONE_MIN_SPREAD));
    traceRadiance(CULL_SECONDARY, surfacePos + n * SURF_BIAS, RAY_TMIN, specDir, 10000.0);

    vec3 reflectedHit;
    vec3 reflectedMotionPrev;
    if (payload.hitT > 0.0) {
        reflectedHit = surfacePos + specDir * payload.hitT;
        reflectedMotionPrev = payloadMaterial() == MATERIAL_OPAQUE ? payload.motionPrev : vec3(0.0, 0.0, 0.0);
    } else {
        reflectedHit = surfacePos + specDir * 1.0e6;
        reflectedMotionPrev = vec3(0.0, 0.0, 0.0);
    }
    vec2 prevNdc = previousReflectionNdc(surfacePos, n, reflectedHit, reflectedMotionPrev);
    return (prevNdc - currentNdc) * 0.5 * size;
}

void refractedGuideHit(vec3 surfacePos, vec3 incidentDir, vec3 surfaceNormal, bool inWaterAtSurface,
                        float materialIor,
                        float rayConeWidth, float rayConeSpread,
                        out vec3 hitCamRel, out vec3 motionPrev, out bool refracted, out vec3 diffuseAlbedo,
                        out vec3 specAlbedo) {
    hitCamRel = surfacePos - worldPush.camOffset;
    motionPrev = vec3(0.0, 0.0, 0.0);
    refracted = false;
    diffuseAlbedo = vec3(0.0, 0.0, 0.0);
    specAlbedo = vec3(0.0, 0.0, 0.0);

    float etaI = inWaterAtSurface ? materialIor : 1.0;
    float etaT = inWaterAtSurface ? 1.0 : materialIor;
    vec3 refractedDir = refract(incidentDir, surfaceNormal, etaI / etaT);
    if (dot(refractedDir, refractedDir) <= 0.0) {
        return;
    }
    refractedDir = normalize(refractedDir);
    refracted = true;

    vec3 ro = surfacePos - surfaceNormal * SURF_BIAS;
    payload.hitT = -1.0;
    payloadSetTraceState(false, rayConeWidth, rayConeSpread);
    traceRadiance(CULL_SECONDARY, ro, RAY_TMIN, refractedDir, 10000.0);
    if (payload.hitT < 0.0) {
        hitCamRel = (ro + refractedDir * 1.0e6) - worldPush.camOffset;
        motionPrev = vec3(0.0, 0.0, 0.0);
        diffuseAlbedo = SKY_DIFF_ALBEDO;
        specAlbedo = SKY_SPEC_ALBEDO;
        return;
    }

    vec3 hitPos = ro + refractedDir * payload.hitT;
    hitCamRel = hitPos - worldPush.camOffset;
    uint material = payloadMaterial();
    motionPrev = material != MATERIAL_WATER ? payload.motionPrev : vec3(0.0, 0.0, 0.0);
    if (material == MATERIAL_OPAQUE) {
        bool pbr = (worldPush.flags & 2u) != 0u;
        diffuseAlbedo = pbr ? payload.albedo * (1.0 - clamp(payloadMetalness(), 0.0, 1.0)) : payload.albedo;
        if (pbr) {
            vec3 f0 = payload.f0;
            float rough = clamp(payloadRoughness(), MIN_ROUGH, 1.0);
            float NoV = clamp(dot(payload.normal, -refractedDir), 0.0, 1.0);
            specAlbedo = rrSpecularAlbedo(f0, rough * rough, NoV);
        }
    }
}

vec3 tracePath(vec3 ro, vec3 rd, float primaryConeSpread, uvec2 pix, uint sampleIndex,
               inout uint seed) {
    vec3 L = vec3(0.0, 0.0, 0.0);
    vec3 throughput = vec3(1.0, 1.0, 1.0);
    float rayConeWidth = 0.0;
    float rayConeSpread = max(primaryConeSpread, RAY_CONE_MIN_SPREAD);
    int maxBounces = int(worldPush.maxBounces);
    int rrStart = maxBounces <= 3 ? 1 : 2;
    bool pbr = (worldPush.flags & 2u) != 0u;
    // RIS is currently force-disabled after being evaluated, mirroring world.rgen.slang's own
    // `risOn = false;` right after its (now-dropped) debug printf — kept for exact behavioral parity.
    bool risOn = worldPush.risCandidates > 0u && worldPush.lightCount > 0u && worldPush.lightBufAddr != 0ul;
    risOn = false;
    uint proposalSeed = pix.x * 1973u + pix.y * 9277u + 26699u
            ^ worldPush.frameIndex * 2654435761u ^ sampleIndex * 2246822519u;
    proposalSeed = pcg(proposalSeed);
    bool inWater = (worldPush.flags & 1u) != 0u;
    vec3 waterExt = waterExtinction(worldPush.waterParams.xyz);
    bool waterWaves = (worldPush.flags & 16u) != 0u;
    bool showCelestial = true;
    for (int bounce = 0; bounce <= maxBounces; bounce++) {
        payload.hitT = -1.0;
        payloadSetTraceState(showCelestial, rayConeWidth, rayConeSpread);
        traceRadiance(bounce == 0 ? CULL_PRIMARY : CULL_SECONDARY, ro, 0.0, rd, 10000.0);

        if (payload.hitT < 0.0) {
            vec3 sky = payload.albedo;
            if (bounce == 0) {
                gv_normal = vec3(0.0, 0.0, 0.0);
                gv_albedo = SKY_DIFF_ALBEDO;
                gv_specAlb = SKY_SPEC_ALBEDO;
                gv_rough = 1.0;
                gv_emission = 0.0;
                gv_emissionSource = EMISSION_SOURCE_NONE;
                gv_hitCamRel = rd * 1.0e6;
                gv_motionHitCamRel = gv_hitCamRel;
                gv_motionUseRefracted = false;
                gv_motionObjDisp = vec3(0.0, 0.0, 0.0);
            }
            L += throughput * sky;
            break;
        }

        if (inWater) {
            throughput *= exp(-waterExt * payload.hitT);
        }

        vec3 n = payload.normal;
        vec3 hitPos = ro + rd * payload.hitT;
        rayConeWidth = max(rayConeWidth + rayConeSpread * max(payload.hitT, 0.0), RAY_CONE_MIN_WIDTH);
        uint material = payloadMaterial();
        if (bounce == 0) {
            gv_emission = payloadEmission();
            gv_emissionSource = payloadEmissionSource();
        }

        if (material == MATERIAL_GLASS) {
            vec3 glassTint = payload.albedo;
            float materialIor = max(payloadIor(), 1.0e-3);
            float transmission = clamp(payloadTransmission(), 0.0, 1.0);
            float cosI = clamp(dot(-rd, n), 0.0, 1.0);
            float F = fresnelDielectric(cosI, 1.0, materialIor);
            if (bounce == 0) {
                gv_normal = n;
                gv_rough = clamp(payloadRoughness(), MIN_ROUGH, 1.0);
                gv_specAlb = vec3(F, F, F);
                gv_albedo = glassTint;
                gv_hitCamRel = hitPos - worldPush.camOffset;
                gv_motionHitCamRel = gv_hitCamRel;
                gv_motionUseRefracted = false;
                gv_motionObjDisp = payload.motionPrev;
            }
            if (rndf(seed) < F) {
                rd = reflect(rd, n);
                ro = hitPos + n * SURF_BIAS;
            } else {
                throughput *= glassTint * transmission;
                ro = hitPos - n * GLASS_TRANSMIT_BIAS;
            }
            showCelestial = true;
            if (bounce >= rrStart) {
                float q = clamp(max(throughput.r, max(throughput.g, throughput.b)), 0.02, 1.0);
                if (rndf(seed) > q) {
                    break;
                }
                throughput /= q;
            }
            continue;
        }

        if (material == MATERIAL_PARTICLE) {
            vec3 albedo = payload.albedo;
            gv_normal = n;
            gv_albedo = albedo;
            gv_specAlb = vec3(0.0, 0.0, 0.0);
            gv_rough = 1.0;
            gv_hitCamRel = hitPos - worldPush.camOffset;
            gv_motionHitCamRel = gv_hitCamRel;
            gv_motionUseRefracted = false;
            gv_motionObjDisp = payload.motionPrev;

            vec3 lightDir = worldPush.lightDir.xyz;
            float lightHalfAngle = worldPush.lightDir.w;
            if (lightHalfAngle > 0.0) {
                lightDir = sampleSquare(lightDir, lightHalfAngle, seed);
            }
            float signedNdl = dot(n, lightDir);
            float ndl = abs(signedNdl);
            if (ndl > 0.0) {
                vec3 shadowOrigin = hitPos + (signedNdl >= 0.0 ? n : -n) * SURF_BIAS;
                vec3 vis = visibility(shadowOrigin, lightDir, 10000.0);
                if (max(vis.r, max(vis.g, vis.b)) > 0.0) {
                    L += throughput * albedo * INV_PI * worldPush.lightRadiance.xyz * ndl * vis;
                }
            }

            // if (risOn) {
                // vec3 v = -rd;
                // Reservoir r = risInitial(hitPos, n, v, rd, albedo, vec3(0.0, 0.0, 0.0), 1.0, false,
                //         true, 0.0, seed, proposalSeed);
                // vec3 risVis;
                // L += throughput * shadeReservoir(r, hitPos, n, v, rd, albedo, vec3(0.0, 0.0, 0.0), 1.0,
                //         false, true, 0.0, risVis);
            // }

            if (bounce >= maxBounces) {
                break;
            }
            throughput *= albedo;
            ro = hitPos + n * SURF_BIAS;
            rd = cosineDir(n, seed);
            rayConeSpread = max(rayConeSpread, RAY_CONE_DIFFUSE_SPREAD);
            showCelestial = false;
            continue;
        }

        if (material == MATERIAL_WATER) {
            float materialIor = max(payloadIor(), 1.0e-3);
            float transmission = clamp(payloadTransmission(), 0.0, 1.0);
            bool materialEntering = payloadWaterEntering();
            if (waterWaves) {
                n = applyWaterWaves(n, hitPos.xz + worldPush.waterAnchor.xy, worldPush.waterParams.w);
            }
            waterExt = waterExtinction(payload.albedo);
            float cosI = clamp(dot(-rd, n), 0.0, 1.0);
            if (bounce == 0) {
                gv_normal = n;
                gv_rough = clamp(payloadRoughness(), MIN_ROUGH, 1.0);
                gv_hitCamRel = hitPos - worldPush.camOffset;
                vec3 refractedAlbedo;
                vec3 refractedSpecAlbedo;
                refractedGuideHit(hitPos, rd, n, inWater, materialIor, rayConeWidth, rayConeSpread,
                        gv_motionHitCamRel, gv_motionObjDisp,
                        gv_motionUseRefracted, refractedAlbedo, refractedSpecAlbedo);
                gv_albedo = refractedAlbedo;
                gv_specAlb = refractedSpecAlbedo;
            }
            float etaI = inWater ? materialIor : 1.0;
            float etaT = inWater ? 1.0 : materialIor;
            float F = fresnelDielectric(cosI, etaI, etaT);
            if (rndf(seed) < F) {
                rd = reflect(rd, n);
                ro = hitPos + n * SURF_BIAS;
            } else {
                rd = refract(rd, n, etaI / etaT);
                throughput *= transmission;
                ro = hitPos - n * SURF_BIAS;
                inWater = materialEntering;
            }
            showCelestial = true;
            if (bounce >= rrStart) {
                float q = clamp(max(throughput.r, max(throughput.g, throughput.b)), 0.02, 1.0);
                if (rndf(seed) > q) {
                    break;
                }
                throughput /= q;
            }
            continue;
        }

        vec3 albedo = payload.albedo;
        float sss = payloadSss();
        vec3 p = hitPos + n * SURF_BIAS;
        vec3 v = -rd;

        float rough = pbr ? clamp(payloadRoughness(), MIN_ROUGH, 1.0) : 1.0;
        float metal = pbr ? clamp(payloadMetalness(), 0.0, 1.0) : 0.0;
        vec3 diffAlb = albedo * (1.0 - metal);
        vec3 F0 = pbr ? payload.f0 : mix(vec3(0.04, 0.04, 0.04), albedo, metal);

        if (bounce == 0) {
            gv_normal = n;
            gv_albedo = pbr ? diffAlb : albedo;
            gv_rough = rough;
            gv_specAlb = pbr ? rrSpecularAlbedo(F0, rough * rough, dot(n, v)) : vec3(0.0, 0.0, 0.0);
            gv_hitCamRel = ro + rd * payload.hitT - worldPush.camOffset;
            gv_motionHitCamRel = gv_hitCamRel;
            gv_motionUseRefracted = false;
            gv_motionObjDisp = payload.motionPrev;
        }

        // float emission = payloadEmission();
        // bool gateEmitter = risOn && payloadEmitterInList();
        // bool gateEmitter = true;
        // if (emission > 0.0 && (!gateEmitter || showCelestial)) {
        //     L += throughput * albedo * emission;
        // }

        vec3 lightDir = worldPush.lightDir.xyz;
        float lightHalfAngle = worldPush.lightDir.w;
        if (lightHalfAngle > 0.0) {
            lightDir = sampleSquare(lightDir, lightHalfAngle, seed);
        }
        float ndl = max(0.0, dot(n, lightDir));
        if (ndl > 0.0) {
            vec3 vis = visibility(p, lightDir, 10000.0);
            if (inWater && waterWaves && shadowVis.a > 0.0) {
                vis *= waterCaustic(p + lightDir * shadowVis.a, lightDir, shadowVis.a);
            }
            if (max(vis.r, max(vis.g, vis.b)) > 0.0) {
                vec3 brdf = diffAlb * INV_PI;
                if (pbr) {
                    vec3 h = normalize(lightDir + v);
                    float ndh = max(0.0, dot(n, h));
                    float ndv = max(1.0e-4, dot(n, v));
                    float vdh = max(0.0, dot(v, h));
                    float D = ggxD(ndh, rough);
                    float G = ggxG1(ndv, rough) * ggxG1(ndl, rough);
                    vec3 F = fresnelSchlick(vdh, F0);
                    brdf += (D * G) * F / (4.0 * ndv * ndl);
                }
                L += throughput * brdf * worldPush.lightRadiance.xyz * ndl * vis;
            }
        }

        // if (risOn) {
            // float activeSss = bounce <= MAX_SSS_BOUNCE ? sss : 0.0;
            // Reservoir r = risInitial(hitPos, n, v, rd, diffAlb, F0, rough, pbr, false, activeSss,
            //         seed, proposalSeed);
            // vec3 risVis;
            // L += throughput * shadeReservoir(r, hitPos, n, v, rd, diffAlb, F0, rough, pbr, false,
            //         activeSss, risVis);
        // }

        if (sss > 0.0 && bounce <= MAX_SSS_BOUNCE) {
            float backNdl = max(0.0, dot(-n, lightDir));
            if (backNdl > 0.0) {
                vec3 visB = visibility(hitPos - n * SURF_BIAS, lightDir, 10000.0);
                if (inWater && waterWaves && shadowVis.a > 0.0) {
                    visB *= waterCaustic(hitPos + lightDir * shadowVis.a, lightDir, shadowVis.a);
                }
                if (max(visB.r, max(visB.g, visB.b)) > 0.0) {
                    float cosT = dot(lightDir, rd);
                    L += throughput * diffAlb * sss * SSS_STRENGTH * hg(cosT, SSS_G) * backNdl * worldPush.lightRadiance.xyz * visB;
                }
            }
        }

        if (pbr) {
            float ps = clamp(luminance(F0) / (luminance(F0) + luminance(diffAlb) + 1.0e-4), 0.1, 0.9);
            if (rndf(seed) < ps) {
                vec3 h = sampleGGXVNDF(n, v, rough, seed);
                vec3 l = reflect(rd, h);
                float ndl2 = dot(n, l);
                if (ndl2 <= 0.0) {
                    break;
                }
                vec3 F = fresnelSchlick(max(0.0, dot(v, h)), F0);
                throughput *= F * ggxG1(ndl2, rough) / ps;
                ro = p;
                rd = l;
                rayConeSpread = max(rayConeSpread, rough * rough * RAY_CONE_GLOSSY_SPREAD_SCALE);
                showCelestial = true;
            } else {
                throughput *= diffAlb / (1.0 - ps);
                ro = p;
                rd = cosineDir(n, seed);
                rayConeSpread = max(rayConeSpread, RAY_CONE_DIFFUSE_SPREAD);
                showCelestial = false;
            }
        } else {
            throughput *= albedo;
            showCelestial = false;
            ro = p;
            rd = cosineDir(n, seed);
            rayConeSpread = max(rayConeSpread, RAY_CONE_DIFFUSE_SPREAD);
        }

        if (bounce >= rrStart) {
            float q = clamp(max(throughput.r, max(throughput.g, throughput.b)), 0.02, 1.0);
            if (rndf(seed) > q) {
                break;
            }
            throughput /= q;
        }
    }
    return L;
}

void main() {
    worldPush = WorldPushBuf(pc.worldPushAddr).data;
    ivec2 pix = ivec2(gl_LaunchIDEXT.xy);
    vec2 size = vec2(gl_LaunchSizeEXT.xy);
    vec2 uv = (vec2(pix) + 0.5) / size;
    vec2 ndc = uv * 2.0 - 1.0;

    vec2 jndc = (uv + worldPush.jitter / size) * 2.0 - 1.0;

    vec4 nearH = worldPush.invViewProj * vec4(jndc.x, jndc.y, 1.0, 1.0);
    vec4 farH = worldPush.invViewProj * vec4(jndc.x, jndc.y, 0.0, 1.0);
    vec3 nearP = nearH.xyz / nearH.w;
    vec3 farP = farH.xyz / farH.w;

    vec3 origin = nearP + worldPush.camOffset;
    vec3 dir = normalize(farP - nearP);
    float rayConeSpread = primaryRayConeSpread(jndc, size, dir);

    uint seed = (uint(pix.x) * 1973u + uint(pix.y) * 9277u + 26699u) ^ (worldPush.frameIndex * 2654435761u);

    uint spp = max(worldPush.spp, 1u);
    vec3 frameRadiance = vec3(0.0, 0.0, 0.0);
    for (uint s = 0u; s < spp; s++) {
        seed = pcg(seed);
        frameRadiance += tracePath(origin, dir, rayConeSpread, uvec2(pix), s, seed);
    }
    frameRadiance /= float(spp);

    vec4 curClip = worldPush.curViewProj * vec4(gv_hitCamRel, 1.0);
    gv_depth = curClip.w > 0.0 ? curClip.z / curClip.w : 0.0;

    imageStore(gNormalImg, pix, vec4(gv_normal, gv_rough));
    imageStore(gAlbedoImg, pix, vec4(gv_albedo, 1.0));
    imageStore(gDepthImg, pix, vec4(gv_depth, 0.0, 0.0, 0.0));
    imageStore(gSpecAlbedoImg, pix, vec4(gv_specAlb, 1.0));

    vec4 prevClip = worldPush.prevViewProj * vec4(gv_motionHitCamRel + worldPush.camDelta - gv_motionObjDisp, 1.0);
    vec2 prevNdc = prevClip.xy / prevClip.w;
    vec2 curNdc = jndc;
    if (gv_motionUseRefracted) {
        vec4 curClipRefr = worldPush.curViewProj * vec4(gv_motionHitCamRel, 1.0);
        curNdc = curClipRefr.xy / curClipRefr.w;
    }
    vec2 motion = (prevNdc - curNdc) * 0.5 * size;
    imageStore(gMotionImg, pix, vec4(motion, 0.0, 0.0));
    vec2 specMotion = specularReflectionMotion(gv_hitCamRel + worldPush.camOffset, dir, jndc, size, rayConeSpread);
    imageStore(gSpecMotionImg, pix, vec4(specMotion, 0.0, 0.0));

    if (pc.debugView != 0u) {
        vec3 dbg;
        if (pc.debugView == 1u) {
            dbg = gv_normal * 0.5 + 0.5;
        } else if (pc.debugView == 2u) {
            dbg = gv_albedo;
        } else if (pc.debugView == 3u) {
            dbg = vec3(gv_depth, gv_depth, gv_depth);
        } else if (pc.debugView == 4u) {
            dbg = vec3(gv_rough, gv_rough, gv_rough);
        } else if (pc.debugView == 6u) {
            dbg = gv_specAlb;
        } else if (pc.debugView == 7u) {
            dbg = vec3(clamp(0.5 + specMotion * 0.05, 0.0, 1.0), 0.5);
        } else if (pc.debugView == 8u) {
            dbg = vec3(gv_emission, gv_emission, gv_emission);
        } else if (pc.debugView == 9u) {
            vec3 sourceColor = gv_emissionSource == EMISSION_SOURCE_LAB_PBR ? vec3(0.15, 0.8, 1.0)
                    : gv_emissionSource == EMISSION_SOURCE_HEURISTIC ? vec3(1.0, 0.45, 0.05)
                    : gv_emissionSource == EMISSION_SOURCE_UNIFORM ? vec3(1.0, 1.0, 1.0)
                    : vec3(0.0, 0.0, 0.0);
            dbg = sourceColor * (gv_emissionSource == EMISSION_SOURCE_NONE
                    ? 0.0 : max(0.2, clamp(gv_emission, 0.0, 1.0)));
        } else {
            dbg = vec3(clamp(0.5 + motion * 0.05, 0.0, 1.0), 0.5);
        }
        imageStore(outImage, pix, vec4(dbg, 1.0));
        return;
    }

    imageStore(outImage, pix, vec4(frameRadiance, 1.0));
}
