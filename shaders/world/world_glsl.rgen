#version 460
#extension GL_EXT_ray_tracing : require
#extension GL_EXT_buffer_reference2 : require
#extension GL_ARB_gpu_shader_int64 : require

// GLSL port of world.rgen.slang (the Slang path tracer, kept in this directory unchanged). This is a
// hand-translated, feature-parity raygen: same primary-ray reconstruction, iterative path-tracing loop
// (NEE toward the sun + RIS emitter NEE + cosine-weighted continuation + Russian roulette), water
// dielectric interface with animated waves/caustics, stained-glass dielectric, particle billboards, and
// the DLSS-RR guide-buffer / motion-vector outputs (including the specular-reflection MV reprojection).
//
// It traces with plain traceRayEXT — no HitObject / ReorderThread (SER): GLSL's HitObject-equivalent
// (GL_EXT_ray_tracing / NV shader-invocation-reorder types) is far less battle-tested than Slang's, so
// this raygen always takes the NO_SER code path that shaders/world/world.rgen.slang's `#ifdef NO_SER`
// branch takes. It is interface-compatible with the (untouched) Slang-compiled world.rchit.spv /
// world.rmiss.spv / world.rahit.spv / shadow.rmiss.spv — same descriptor bindings, push-constant layout,
// WorldPush/Light*/Payload struct shapes — so those stages keep running exactly as before.
//
// See world.rgen.slang for the prose design notes behind each piece of this file; comments below are
// trimmed to what differs or what a GLSL reader specifically needs.

layout(push_constant) uniform PushConstants {
    uint64_t worldPushAddr;
    uint64_t tableAddr;
    uint64_t entityTableAddr;
    uint64_t materialTableAddr;
    uint frameIndex;
    uint debugView;
} pc;

layout(set = 0, binding = 0) uniform accelerationStructureEXT topLevelAS;
layout(set = 0, binding = 1, rgba16f) uniform writeonly image2D outImage;
layout(set = 0, binding = 3, rgba16f) uniform writeonly image2D gNormalImg;
layout(set = 0, binding = 4, rgba16f) uniform writeonly image2D gAlbedoImg;
layout(set = 0, binding = 5, r32f)    uniform writeonly image2D gDepthImg;
layout(set = 0, binding = 6, rg16f)   uniform writeonly image2D gMotionImg;
layout(set = 0, binding = 7, rgba16f) uniform writeonly image2D gSpecAlbedoImg;
layout(set = 0, binding = 8, rg16f)   uniform writeonly image2D gSpecMotionImg;

// ===== Shared cross-stage types (mirrors world_common.slang) ============================

struct BreakEntry {
    ivec4 posSlot;
};

struct WorldPush {
    mat4  invViewProj;
    vec3  camOffset;
    uint64_t tableAddr;
    uint  frameIndex;
    mat4  prevViewProj;
    vec3  camDelta;
    uint  spp;
    vec2  jitter;
    uint64_t entityTableAddr;
    uint  flags;
    uint  maxBounces;
    vec4  sunDir;
    vec4  lightDir;
    vec4  lightRadiance;
    vec4  moonDir;
    vec4  celestial;
    vec4  sunUv;
    vec4  moonUv;
    vec4  waterParams;
    vec4  waterAnchor;
    mat4  curViewProj;
    uint  breakCount;
    BreakEntry breaking[8];
    uint64_t lightBufAddr;
    uint64_t lightAliasAddr;
    uint64_t lightLocalAliasAddr;
    vec4  lightRebase;
    uint64_t lightGridCellAddr;
    uint64_t lightGridSpanAddr;
    vec4  lightGridOrigin;
    ivec4 lightGridDims;
    uint  lightCount;
    uint  risCandidates;
};

struct Light {
    vec4 posArea;
    vec4 halfULe;
    vec4 halfVSection;
};

struct LightAlias {
    uint  aliasIndex;
    float accept;
};

struct LightGridCell {
    uint  spanOffset;
    uint  spanCount;
    float invWeightSum;
};

struct LightGridSpan {
    uint  firstLight;
    uint  aliasFirstLight;
    uint  packedLightCounts;
    float accept;
};

// Radiance-ray payload (location 0). Member order/types are a cross-stage ABI shared with
// world.rchit.slang / world.rmiss.slang — do not reorder without updating both sides.
struct Payload {
    vec3  albedo;
    vec3  normal;
    float hitT;
    vec3  motionPrev;
    vec3  f0;
    uint  flags;
    uint  roughMetal;
    uint  emissionSss;
    uint  iorTransmission;
    uint  rayCone;
};

layout(buffer_reference, std430, buffer_reference_align = 16) readonly buffer WorldPushBuf { WorldPush data; };
layout(buffer_reference, std430, buffer_reference_align = 16) readonly buffer LightBuf { Light d[]; };
layout(buffer_reference, std430, buffer_reference_align = 4)  readonly buffer LightAliasBuf { LightAlias d[]; };
layout(buffer_reference, std430, buffer_reference_align = 4)  readonly buffer LightGridCellBuf { LightGridCell d[]; };
layout(buffer_reference, std430, buffer_reference_align = 4)  readonly buffer LightGridSpanBuf { LightGridSpan d[]; };

layout(location = 0) rayPayloadEXT Payload payload;
layout(location = 1) rayPayloadEXT vec4 shadowVis; // rgb = transmittance; a = nearest water-crossing t (-1 = none)

WorldPush worldPush;

// First-hit (primary-visibility) guide attributes, captured at bounce 0 of tracePath.
vec3  gv_normal;
vec3  gv_albedo;
vec3  gv_specAlb;
float gv_rough;
float gv_emission;
uint  gv_emissionSource;
float gv_depth;
vec3  gv_hitCamRel;
vec3  gv_motionHitCamRel;
bool  gv_motionUseRefracted;
vec3  gv_motionObjDisp;

// ===== Payload flag helpers (mirrors world_common.slang constants) ======================

const uint PAYLOAD_SHOW_CELESTIAL = 4u;
const uint PAYLOAD_EMITTER_IN_LIST = 128u;
const uint PAYLOAD_WATER_ENTERING = 8u;
const uint PAYLOAD_EMISSION_SOURCE_SHIFT = 4u;
const uint PAYLOAD_EMISSION_SOURCE_MASK = 7u;
const uint EMISSION_SOURCE_NONE = 0u;
const uint EMISSION_SOURCE_UNIFORM = 1u;
const uint EMISSION_SOURCE_HEURISTIC = 2u;
const uint EMISSION_SOURCE_LAB_PBR = 3u;

const uint PAYLOAD_MATERIAL_MASK = 3u;
const uint MATERIAL_OPAQUE = 0u;
const uint MATERIAL_WATER = 1u;
const uint MATERIAL_PARTICLE = 2u;
const uint MATERIAL_GLASS = 3u;

uint payloadMaterial() { return payload.flags & PAYLOAD_MATERIAL_MASK; }
uint payloadEmissionSource() {
    return (payload.flags >> PAYLOAD_EMISSION_SOURCE_SHIFT) & PAYLOAD_EMISSION_SOURCE_MASK;
}
bool payloadWaterEntering() { return (payload.flags & PAYLOAD_WATER_ENTERING) != 0u; }
// bool payloadEmitterInList() { return (payload.flags & PAYLOAD_EMITTER_IN_LIST) != 0u; }
float payloadRoughness() { return unpackHalf2x16(payload.roughMetal).x; }
float payloadMetalness() { return unpackHalf2x16(payload.roughMetal).y; }
float payloadEmission() { return unpackHalf2x16(payload.emissionSss).x; }
float payloadSss() { return unpackHalf2x16(payload.emissionSss).y; }
float payloadIor() { return unpackHalf2x16(payload.iorTransmission).x; }
float payloadTransmission() { return unpackHalf2x16(payload.iorTransmission).y; }
void payloadSetTraceState(bool showCelestial, float rayConeWidth, float rayConeSpread) {
    payload.flags = showCelestial ? PAYLOAD_SHOW_CELESTIAL : 0u;
    payload.rayCone = packHalf2x16(vec2(rayConeWidth, rayConeSpread));
}

const float PI = 3.14159265359;
const float INV_PI = 0.31830988618;

const float SURF_BIAS = 0.005;
const float RAY_TMIN = 0.001;

const float WATER_IOR = 1.333;
const vec3 SKY_SPEC_ALBEDO = vec3(0.5, 0.5, 0.5);
const vec3 SKY_DIFF_ALBEDO = vec3(0.5, 0.5, 0.5);

const float GLASS_TRANSMIT_BIAS = 1.0e-4;

const float RAY_CONE_MIN_SPREAD = 1.0e-5;
const float RAY_CONE_MIN_WIDTH = 1.0e-5;
const float RAY_CONE_DIFFUSE_SPREAD = 0.25;
const float RAY_CONE_GLOSSY_SPREAD_SCALE = 0.35;

const float WATER_DENSITY = 0.05;
const vec3 WATER_ABSORB_FLOOR = vec3(0.015, 0.010, 0.008);
vec3 waterExtinction(vec3 tint) {
    return WATER_ABSORB_FLOOR + WATER_DENSITY * (vec3(1.0, 1.0, 1.0) - clamp(tint, 0.0, 1.0));
}

const float WATER_WAVE_STRENGTH = 0.3;
const float WAVE_SPEED = 0.8;
const int   WAVE_COUNT = 10;
const float WAVE_G = 9.81;
const vec2 WAVE_WIND = normalize(vec2(1.0, 0.35));
const float WAVE_MEANDER = 1.1;
vec2 waterWaveGrad(vec2 p, float t) {
    const float Q[10] = float[10](0.030, 0.035, 0.042, 0.050, 0.060, 0.065, 0.065, 0.058, 0.048, 0.038);
    t *= WAVE_SPEED;
    vec2 g = vec2(0.0, 0.0);
    float lambda = 14.0;
    for (int i = 0; i < WAVE_COUNT; i++) {
        float k = 2.0 * PI / lambda;
        float w = sqrt(WAVE_G * k);
        float spread = (0.15 + 0.11 * float(i)) * sin(float(i) * 2.4 + 1.3);
        float cs = cos(spread), sn = sin(spread);
        vec2 d = vec2(WAVE_WIND.x * cs - WAVE_WIND.y * sn, WAVE_WIND.x * sn + WAVE_WIND.y * cs);
        float ph = k * dot(d, p) - w * t + 1.7 * float(i) * float(i);
        vec2 dph = k * d;
        if (i < 4) {
            vec2 pd = vec2(-d.y, d.x);
            float wph = 0.4 * k * dot(pd, p) + 0.5 * w * t;
            ph += WAVE_MEANDER * sin(wph);
            dph += (WAVE_MEANDER * cos(wph) * 0.4 * k) * pd;
        }
        float S = 1.2 + 0.12 * float(i);
        float e = exp(S * (sin(ph) - 1.0));
        g += (Q[i] / k) * (S * cos(ph) * e) * dph;
        lambda /= 1.5;
    }
    return g * WATER_WAVE_STRENGTH;
}

vec3 applyWaterWaves(vec3 nGeo, vec2 worldXZ, float t) {
    if (abs(nGeo.y) < 0.5) return nGeo;
    vec2 grad = waterWaveGrad(worldXZ, t);
    vec3 up = normalize(vec3(-grad.x, 1.0, -grad.y));
    return nGeo.y >= 0.0 ? up : -up;
}

const float CAUSTIC_EPS = 0.25;
const float CAUSTIC_MAX = 6.0;

vec2 causticLanding(vec2 xz, float t, vec3 inc, float h) {
    vec2 g = waterWaveGrad(xz, t);
    vec3 nw = normalize(vec3(-g.x, 1.0, -g.y));
    vec3 rdw = refract(inc, nw, 1.0 / WATER_IOR);
    return xz + rdw.xz * (h / max(-rdw.y, 0.05));
}

float waterCaustic(vec3 exitPos, vec3 lightDir, float waterDist) {
    float fade = smoothstep(0.06, 0.18, lightDir.y);
    if (fade <= 0.0) return 1.0;
    float h = max(waterDist * lightDir.y, 0.05);
    float t = worldPush.waterParams.w;
    vec3 inc = -lightDir;
    vec2 base = exitPos.xz + worldPush.waterAnchor.xy;
    vec2 p0 = causticLanding(base, t, inc, h);
    vec2 px = causticLanding(base + vec2(CAUSTIC_EPS, 0.0), t, inc, h);
    vec2 pz = causticLanding(base + vec2(0.0, CAUSTIC_EPS), t, inc, h);
    float det = abs((px.x - p0.x) * (pz.y - p0.y) - (px.y - p0.y) * (pz.x - p0.x));
    float focus = (CAUSTIC_EPS * CAUSTIC_EPS) / max(det, 1.0e-5);
    return mix(1.0, min(focus, CAUSTIC_MAX), fade);
}

const float MIN_ROUGH = 0.045;

float luminance(vec3 c) { return dot(c, vec3(0.2126, 0.7152, 0.0722)); }

float ggxD(float ndh, float rough) {
    float a = rough * rough;
    float a2 = a * a;
    float d = ndh * ndh * (a2 - 1.0) + 1.0;
    return a2 / (PI * d * d + 1.0e-7);
}

float ggxG1(float ndx, float rough) {
    float a = rough * rough;
    float a2 = a * a;
    return 2.0 * ndx / (ndx + sqrt(a2 + (1.0 - a2) * ndx * ndx) + 1.0e-7);
}

vec3 fresnelSchlick(float cosT, vec3 f0) {
    float m = clamp(1.0 - cosT, 0.0, 1.0);
    float m2 = m * m;
    return f0 + (1.0 - f0) * (m2 * m2 * m);
}

const float SSS_G = 0.6;
const float SSS_STRENGTH = 1.0;
const int   MAX_SSS_BOUNCE = 1;
float hg(float cosT, float g) {
    float g2 = g * g;
    return (1.0 - g2) / (4.0 * PI * pow(max(0.0, 1.0 + g2 - 2.0 * g * cosT), 1.5));
}

vec3 rrSpecularAlbedo(vec3 specularColor, float alpha, float NoV) {
    NoV = abs(NoV);
    float NoV2 = NoV * NoV;
    float alpha2 = alpha * alpha;
    vec4 X = vec4(1.0, NoV, NoV2, NoV * NoV2);
    vec4 Y = vec4(1.0, alpha, alpha2, alpha * alpha2);

    vec2 m1 = vec2(
            dot(vec2(0.99044, -1.28514), X.xy),
            dot(vec2(1.29678, -0.755907), X.xy));
    vec3 Xxyw = vec3(X.x, X.y, X.w);
    vec3 m2 = vec3(
            dot(vec3(1.0, 2.92338, 59.4188), Xxyw),
            dot(vec3(20.3225, -27.0302, 222.592), Xxyw),
            dot(vec3(121.563, 626.13, 316.627), Xxyw));
    float bias = dot(m1, Y.xy) / max(dot(m2, vec3(Y.x, Y.y, Y.w)), 1.0e-7);

    vec2 m3 = vec2(
            dot(vec2(0.0365463, 3.32707), X.xy),
            dot(vec2(9.0632, -9.04756), X.xy));
    vec3 Xxzw = vec3(X.x, X.z, X.w);
    vec3 m4 = vec3(
            dot(vec3(1.0, 3.59685, -1.36772), Xxzw),
            dot(vec3(9.04401, -16.3174, 9.22949), Xxzw),
            dot(vec3(5.56589, 19.7886, -20.2123), Xxzw));
    float scale = dot(m3, Y.xy) / max(dot(m4, vec3(Y.x, Y.y, Y.w)), 1.0e-7);

    bias *= clamp(specularColor.g * 50.0, 0.0, 1.0);
    return specularColor * max(0.0, scale) + vec3(max(0.0, bias), max(0.0, bias), max(0.0, bias));
}

float fresnelDielectric(float cosI, float etaI, float etaT) {
    float sinT2 = (etaI * etaI) / (etaT * etaT) * max(0.0, 1.0 - cosI * cosI);
    if (sinT2 >= 1.0) {
        return 1.0;
    }
    float cosT = sqrt(1.0 - sinT2);
    float rs = (etaI * cosI - etaT * cosT) / (etaI * cosI + etaT * cosT);
    float rp = (etaI * cosT - etaT * cosI) / (etaI * cosT + etaT * cosI);
    return 0.5 * (rs * rs + rp * rp);
}

uint pcg(inout uint s) {
    s = s * 747796405u + 2891336453u;
    uint w = ((s >> ((s >> 28u) + 4u)) ^ s) * 277803737u;
    return (w >> 22u) ^ w;
}
float rndf(inout uint s) { return float(pcg(s)) * (1.0 / 4294967296.0); }

vec3 primaryRayDir(vec2 ndc) {
    vec4 nearH = worldPush.invViewProj * vec4(ndc.x, ndc.y, 1.0, 1.0);
    vec4 farH = worldPush.invViewProj * vec4(ndc.x, ndc.y, 0.0, 1.0);
    vec3 nearP = nearH.xyz / nearH.w;
    vec3 farP = farH.xyz / farH.w;
    return normalize(farP - nearP);
}

float primaryRayConeSpread(vec2 ndc, vec2 size, vec3 dir) {
    vec2 onePixelNdc = 2.0 / size;
    vec3 dx = primaryRayDir(ndc + vec2(onePixelNdc.x, 0.0));
    vec3 dy = primaryRayDir(ndc + vec2(0.0, onePixelNdc.y));
    return max(max(length(cross(dir, dx)), length(cross(dir, dy))), RAY_CONE_MIN_SPREAD);
}

vec3 cosineDir(vec3 n, inout uint s) {
    float u1 = rndf(s);
    float u2 = rndf(s);
    float r = sqrt(u1);
    float phi = 6.2831853 * u2;
    vec3 t = normalize(abs(n.x) > 0.9 ? vec3(0.0, 1.0, 0.0) : vec3(1.0, 0.0, 0.0));
    vec3 b = normalize(cross(n, t));
    t = cross(b, n);
    vec3 local = vec3(r * cos(phi), r * sin(phi), sqrt(max(0.0, 1.0 - u1)));
    return normalize(local.x * t + local.y * b + local.z * n);
}

vec3 sampleSquare(vec3 axis, float halfAngle, inout uint s) {
    vec3 right = normalize(cross(axis, worldPush.celestial.xyz));
    vec3 up = cross(right, axis);
    float t = tan(halfAngle);
    float u = (rndf(s) * 2.0 - 1.0) * t;
    float v = (rndf(s) * 2.0 - 1.0) * t;
    return normalize(axis + u * right + v * up);
}

vec3 sampleGGXVNDF(vec3 n, vec3 ve, float rough, inout uint s) {
    vec3 t = normalize(abs(n.x) > 0.9 ? vec3(0.0, 1.0, 0.0) : vec3(1.0, 0.0, 0.0));
    vec3 b = normalize(cross(n, t));
    t = cross(b, n);
    vec3 Ve = vec3(dot(ve, t), dot(ve, b), dot(ve, n));
    float a = rough * rough;
    vec3 Vh = normalize(vec3(a * Ve.x, a * Ve.y, Ve.z));
    float lensq = Vh.x * Vh.x + Vh.y * Vh.y;
    vec3 T1 = lensq > 0.0 ? vec3(-Vh.y, Vh.x, 0.0) * inversesqrt(lensq) : vec3(1.0, 0.0, 0.0);
    vec3 T2 = cross(Vh, T1);
    float u1 = rndf(s);
    float u2 = rndf(s);
    float r = sqrt(u1);
    float phi = 6.2831853 * u2;
    float p1 = r * cos(phi);
    float p2 = r * sin(phi);
    float ss = 0.5 * (1.0 + Vh.z);
    p2 = (1.0 - ss) * sqrt(1.0 - p1 * p1) + ss * p2;
    vec3 Nh = p1 * T1 + p2 * T2 + sqrt(max(0.0, 1.0 - p1 * p1 - p2 * p2)) * Vh;
    vec3 Ne = normalize(vec3(a * Nh.x, a * Nh.y, max(0.0, Nh.z)));
    return normalize(Ne.x * t + Ne.y * b + Ne.z * n);
}

const uint CULL_SECONDARY = 0x01u;
const uint CULL_PRIMARY = 0x02u;
const uint TERRAIN_BUCKETS = 4u;
const uint SBT_RADIANCE = 0u;
const uint SBT_SHADOW = TERRAIN_BUCKETS;
const uint SBT_STRIDE_BUCKET = 1u;

// Plain traceRayEXT — no HitObject / ReorderThread (SER), matching the NO_SER branch of
// world.rgen.slang. See the header comment for why.
void traceRadiance(uint cullMask, vec3 ro, float tmin, vec3 rd, float tmax) {
    traceRayEXT(topLevelAS, gl_RayFlagsNoneEXT, cullMask,
            int(SBT_RADIANCE), int(SBT_STRIDE_BUCKET), 0, ro, tmin, rd, tmax, 0);
}

vec3 visibility(vec3 origin, vec3 dir, float tmax) {
    shadowVis = vec4(1.0, 1.0, 1.0, -1.0);
    // Shadow SBT records run any-hit only for cutout/translucent/water. Solid blocks terminate
    // traversal with no shader invoked at all (SKIP_CLOSEST_HIT_SHADER), so shadowVis.a == 1.0
    // (only ever written by shadow.rmiss) is the traversal-missed signal.
    // missIndex=1: shadow.rmiss (SBT miss index 1) — the SER path never triggers this (HitObject.IsMiss()
    // without Invoke), but a plain traceRayEXT genuinely invokes the miss shader on escape, so this must
    // point at shadow.rmiss (sets shadowVis.a=1.0), not miss index 0 (world.rmiss, the sky/Payload miss).
    traceRayEXT(topLevelAS,
            gl_RayFlagsTerminateOnFirstHitEXT | gl_RayFlagsSkipClosestHitShaderEXT,
            CULL_SECONDARY, int(SBT_SHADOW), int(SBT_STRIDE_BUCKET), 1,
            origin, RAY_TMIN, dir, tmax, 1);
    return shadowVis.a == 1.0 ? shadowVis.rgb : vec3(0.0, 0.0, 0.0);
}

